---
Checks: >
  bugprone-*,
  modernize-use-nullptr,
  modernize-use-override,
  performance-unnecessary-copy-initialization,
  readability-container-size-empty,
  readability-redundant-member-init,
  readability-redundant-casting,
  -bugprone-invalid-enum-default-initialization,
  -bugprone-easily-swappable-parameters,
  -bugprone-throwing-static-initialization,
  -misc-include-cleaner

# Disabled checks rationale:
#   misc-include-cleaner              — broken for C++23 modules (can't see module imports)
#   bugprone-invalid-enum-default-initialization — zero-init D3D12 structs with ={} is standard
#   bugprone-easily-swappable-parameters         — Win32 callback signatures are not ours to change
#   bugprone-throwing-static-initialization      — gainput::InputManager static is intentional

WarningsAsErrors: ''
HeaderFilterRegex: '^C:/Users/ben/projects/dx12_mini_engine/src/.*'
